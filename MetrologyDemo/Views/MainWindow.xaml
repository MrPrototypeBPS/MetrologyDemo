<Window x:Class="MetrologyDemo.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:viewmodels="clr-namespace:MetrologyDemo.ViewModels"
        mc:Ignorable="d"
        Title="CMM Data Visualizer" Height="450" Width="600"
        WindowStartupLocation="CenterScreen">

    <Window.DataContext>
        <viewmodels:MainViewModel />
    </Window.DataContext>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
            <Button Content="Load CMM Data" 
                    Command="{Binding LoadDataCommand}" 
                    Width="120" Height="30" 
                    Padding="5"/>

            <TextBlock Text="Loading data..." 
                       VerticalAlignment="Center" 
                       Margin="15,0,0,0" 
                       Foreground="DarkOrange"
                       FontWeight="SemiBold">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsBusy}" Value="True">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>
        </StackPanel>

        <DataGrid Grid.Row="1" 
                  ItemsSource="{Binding MeasurementPoints}" 
                  AutoGenerateColumns="False" 
                  CanUserAddRows="False"
                  AlternatingRowBackground="#FFF0F0F0"
                  GridLinesVisibility="Vertical">
            <DataGrid.Columns>
                <DataGridTextColumn Header="X (mm)" Binding="{Binding X}" Width="*" />
                <DataGridTextColumn Header="Y (mm)" Binding="{Binding Y}" Width="*" />
                <DataGridTextColumn Header="Z (mm)" Binding="{Binding Z}" Width="*" />
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Window>